# ══════════════════════════════════════════════════
# REALSYNC DYNAMICS — ENVIRONMENT VARIABLES
# Copy to .env.local for local dev
# Set all in Vercel → Settings → Environment Variables
# ══════════════════════════════════════════════════

# ── 1. SUPABASE ─────────────────────────────────
# supabase.com → Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://DEIN_PROJEKT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── 2. OAUTH PROVIDERS ──────────────────────────
# Google: console.cloud.google.com → OAuth 2.0 Client IDs
# Supabase aktiviert OAuth, Keys nur dort eintragen

# ── 3. STRIPE ───────────────────────────────────
# dashboard.stripe.com → Developers → API Keys
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Produkte anlegen: dashboard.stripe.com → Products
# Monatliche Preise:
STRIPE_BRONZE_PRICE_ID=price_...
STRIPE_SILBER_PRICE_ID=price_...
STRIPE_GOLD_PRICE_ID=price_...
STRIPE_PLATIN_PRICE_ID=price_...
STRIPE_DIAMANT_PRICE_ID=price_...

# Jährliche Preise (-20%):
STRIPE_BRONZE_YEARLY_PRICE_ID=price_...
STRIPE_SILBER_YEARLY_PRICE_ID=price_...
STRIPE_GOLD_YEARLY_PRICE_ID=price_...
STRIPE_PLATIN_YEARLY_PRICE_ID=price_...
STRIPE_DIAMANT_YEARLY_PRICE_ID=price_...

# ── 4. APP ──────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://realsync-platform.vercel.app
