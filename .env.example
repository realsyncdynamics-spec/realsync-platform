# ===========================================
# RealSync Platform — Environment Variables
# ===========================================

# Public site URL (where this app is deployed)
NEXT_PUBLIC_SITE_URL=https://realsyncdynamics.de

# ---- Supabase ----
# Project: ebljyceifhnlzhjfyxup
NEXT_PUBLIC_SUPABASE_URL=https://ebljyceifhnlzhjfyxup.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_BqKKWFM8zcb8R5NXifVgjA_pIYunrhB
# Service role key — from Supabase Dashboard → Settings → API. SECRET!
SUPABASE_SERVICE_ROLE_KEY=

# ---- Stripe ----
# Live secret key — from Stripe Dashboard → API keys. SECRET!
STRIPE_SECRET_KEY=
# Webhook signing secret — from Stripe Dashboard → Webhooks. SECRET!
STRIPE_WEBHOOK_SECRET=
# One-off Price ID for the €9,90 / 90-day Starter offer.
# Stripe Dashboard → Products → Add product → One-time price → copy price_...
STRIPE_STARTER_PRICE_ID=

# ---- Admin (for protected routes) ----
# Comma-separated list of admin email addresses
ADMIN_EMAILS=dominik@realsyncdynamics.de

# ---- Cron / lifecycle ----
# Shared secret that protects /api/cron/lifecycle (Vercel Cron auto-passes
# x-vercel-cron=1, so CRON_SECRET is only required for manual invocations).
CRON_SECRET=

# ---- Email (optional, used by /api/cron/lifecycle) ----
# Without RESEND_API_KEY the cron logs and still records sends — upgrade
# later without re-firing the backlog.
RESEND_API_KEY=
RESEND_FROM=noreply@realsyncdynamics.de

# ---- Starter-purchase notifications (optional) ----
# Slack incoming-webhook URL (or Discord — add /slack to the Discord
# webhook URL). Receives a short message on every paid Starter signup.
STARTER_NOTIFY_WEBHOOK_URL=
